# Use a flat, npm-style node_modules so pnpm creates plain symlinks in
# node_modules/.bin (not NODE_PATH shell shims). Hugo >= 0.161's css.TailwindCSS
# resolves the `tailwindcss` binary by reading node_modules/.bin/tailwindcss; its
# entry-point regex doesn't understand pnpm's isolated-linker shim, which makes
# the build fail with: binary "tailwindcss" is not a Node.js script.
node-linker=hoisted
